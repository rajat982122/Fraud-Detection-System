      "targets": [
        {
          "dataset": "fraud_db",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, COUNT(*) AS fraud_alerts FROM fraud_predictions WHERE is_fraud = 1 AND $__timeFilter(processed_at)",
          "refId": "A"
        }
      ],
      "title": "Fraud Alerts",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "mysql",
        "uid": "fraud-mysql"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "decimals": 2,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "hidden",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "dataset": "fraud_db",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(processed_at, '1m'), ROUND(100 * SUM(is_fraud) / NULLIF(COUNT(*), 0), 2) AS fraud_rate FROM fraud_predictions WHERE $__timeFilter(processed_at) GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Fraud Rate (%)",
      "type": "timeseries"
    }
